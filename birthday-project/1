  <!-- ══════════════════════════════════════════════════════
       SCRIPTS — load order matters
  ══════════════════════════════════════════════════════ -->

  <!-- 1. Content data (must load first — all other scripts depend on it) -->
  <script src="data/content.js"></script>

  <!-- 2. Core utilities -->
  <script src="js/particles.js"></script>
  <script src="js/app.js"></script>
  <script src="js/countdown.js"></script>

  <!-- 3. Feature scripts -->
  <script src="js/quiz.js"></script>
  <script src="js/wheel.js"></script>
  <script src="js/gallery.js"></script>
  <script src="js/story.js"></script>
  <script src="js/memory.js"></script>
  <script src="js/guessdate.js"></script>
  <script src="js/reveal.js"></script>

  <!-- 4. Page bootstrap (inline — wires everything together) -->
  <script>
    // ── Password check ────────────────────────────────────
    function checkPw() {
      const val = document.getElementById('pw-in').value.trim().toLowerCase();
      if (val === CONFIG.password.toLowerCase()) {
        unlockSite();
      } else {
        const err = document.getElementById('pw-err');
        err.textContent = "That's not quite it, love. Try again 🌸";
        document.getElementById('pw-in').value = '';
        setTimeout(() => err.textContent = '', 2500);
      }
    }
    document.getElementById('pw-in').addEventListener('keydown', e => {
      if (e.key === 'Enter') checkPw();
    });

    // ── Story chapters are now static HTML in #pg-story ──

    // ── Letter accordion (inline expand, no modal) ────────
    function lpToggle(id) {
      const card = document.getElementById(id);
      const wasOpen = card.classList.contains('open');
      // Close all
      document.querySelectorAll('.lp-card').forEach(c => c.classList.remove('open'));
      // Open clicked if it wasn't already open
      if (!wasOpen) {
        card.classList.add('open');
        setTimeout(() => {
          card.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }, 80);
      }
    }

    // ── Letters accordion ─────────────────────────────────
    function lpToggle(id) {
      const card = document.getElementById(id);
      const wasOpen = card.classList.contains('open');
      document.querySelectorAll('.lp-card').forEach(c => c.classList.remove('open'));
      if (!wasOpen) {
        card.classList.add('open');
        setTimeout(() => card.scrollIntoView({ behavior: 'smooth', block: 'start' }), 80);
      }
    }

    // ── Reveal page content is now static HTML ─────────────
    // (initReveal removed — no placeholder IDs needed)

    // ── openGame: navigate to a game sub-page & init it ───
    const GAME_INITS = {
      'pg-quiz':      () => initQuizPage(),
      'pg-spin':      () => { initWheel(); },
      'pg-memory':    () => initMemory(),
      'pg-guessdate': () => initGuessDate(),
    };
    const GAME_PAGES = ['pg-quiz','pg-spin','pg-memory','pg-guessdate'];

    function openGame(id) {
      go(id);
      setTimeout(() => { if (GAME_INITS[id]) GAME_INITS[id](); }, 650);
    }

    // ── INIT ALL ──────────────────────────────────────────
    initParticles();
    initCountdown();
    initDailyMessage();
    initLockButton();
    // Letters are now static HTML with inline accordion (lpToggle)
    initGallery();
    initWheel();

    // Hook story page init/destroy + reveal page init into go()
    const _goOriginal = go;
    window.go = function(id, instant) {
      if (currentPage === 'pg-story' && id !== 'pg-story') destroyStoryPage();
      _goOriginal(id, instant);
      if (id === 'pg-story')  { setTimeout(initStoryPage,  instant ? 0 : 650); }
      if (id === 'pg-reveal') { setTimeout(initRevealPage, instant ? 0 : 650); }
    };
    window.unlockSite = function() {
      document.getElementById('site-nav').style.display = 'flex';
      go('pg-story');
    };
  </script>

